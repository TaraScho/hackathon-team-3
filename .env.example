# Datadog credentials — org-level write access
# App key must have Actions API enabled
export DD_API_KEY=<your-datadog-api-key>
export DD_APP_KEY=<your-datadog-app-key>

# AWS CLI profile with IAM permissions:
#   iam:CreateRole, iam:GetRole, iam:PutRolePolicy, iam:UpdateAssumeRolePolicy,
#   sts:GetCallerIdentity
export AWS_PROFILE=<your-aws-profile>
