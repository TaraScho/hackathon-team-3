{
  "title": "SKO26 Tail Sampling",
  "description": "[[suggested_dashboards]]",
  "widgets": [
    {
      "id": 108586516347065,
      "definition": {
        "title": "Overall Sampled Traces",
        "title_size": "16",
        "title_align": "left",
        "type": "query_value",
        "requests": [
          {
            "response_format": "scalar",
            "queries": [
              {
                "data_source": "metrics",
                "name": "query1",
                "query": "sum:otelcol_processor_tail_sampling_count_traces_sampled_total{decision:sampled,$env}.as_count()",
                "aggregator": "avg"
              },
              {
                "data_source": "metrics",
                "name": "query2",
                "query": "sum:otelcol_processor_tail_sampling_count_traces_sampled_total{decision:not_sampled ,$env}.as_count()",
                "aggregator": "avg"
              }
            ],
            "formulas": [
              {
                "number_format": {
                  "unit": {
                    "type": "canonical_unit",
                    "unit_name": "percent"
                  }
                },
                "formula": "100 * (query1 / (query1 + query2))"
              }
            ]
          }
        ],
        "autoscale": true,
        "precision": 1,
        "timeseries_background": {
          "type": "bars",
          "yaxis": {}
        }
      },
      "layout": {
        "x": 0,
        "y": 0,
        "width": 12,
        "height": 3
      }
    },
