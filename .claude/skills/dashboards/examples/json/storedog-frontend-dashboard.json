          {
            "id": 733394574271381,
            "definition": {
              "title": "% of Time Spent by All Services on store-frontend",
              "title_size": "16",
              "title_align": "left",
              "show_legend": false,
              "legend_layout": "auto",
              "legend_columns": [
                "avg",
                "min",
                "max",
                "value",
                "sum"
              ],
              "time": {},
              "type": "timeseries",
              "requests": [
                {
                  "response_format": "timeseries",
                  "queries": [
                    {
                      "data_source": "metrics",
                      "name": "query1",
                      "query": "sum:trace.web.request.exec_time.by_service{env:im-workshop,service:store-frontend} by {sublayer_service}.rollup(sum).fill(zero)"
                    },
                    {
                      "data_source": "metrics",
                      "name": "query2",
                      "query": "sum:trace.web.request.exec_time.by_service{env:im-workshop,service:store-frontend}.rollup(sum).fill(zero)"
                    }
                  ],
                  "formulas": [
                    {
                      "formula": "query1 * 100 / query2"
                    }
                  ],
                  "style": {
                    "palette": "dog_classic",
                    "line_type": "solid",
                    "line_width": "normal"
                  },
                  "display_type": "area"
                }
              ],
              "yaxis": {
                "max": "100"
              }
            },
            "layout": {
              "x": 0,
              "y": 0,
              "width": 12,
              "height": 3
            }
