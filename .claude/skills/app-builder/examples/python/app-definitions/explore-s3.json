        "id": "6cea8cc0-87be-4125-8610-c112b66d5d5d",
        "name": "ListBuckets",
        "type": "action",
        "properties": {
          "outputs": "${((outputs) => {// Use `outputs` to reference the query's unformatted output.\n\n// TODO: Apply transformations to the raw query output\n\n// return outputs.buckets?.filter(b => b.Name.toLowerCase().includes(\"ri-demo-\"))\n// .map(b => ({\n//     ...b,\n//     Name: b.Name.replace(\"ri-demo-\", \"\")\n// }))\n\nreturn outputs;\n\n})(self.rawOutputs)}",
          "spec": {
            "connectionId": "2a8a6d56-4c60-4772-9f1e-69bafed9f0ae",
            "fqn": "com.datadoghq.aws.s3.list_s3_buckets",
            "inputs": {
              "region": "us-east-1"
            }
          }
        }
      },
      {
        "id": "e37cecd3-2f11-4c44-b39b-d4c33efbcfe1",
        "name": "ListObjects",
        "type": "action",
        "properties": {
          "condition": "${!!listBucketsTable.selectedRow}",
          "onlyTriggerManually": false,
          "outputs": "${((outputs) => {const prefix = (path.value === '/' ? '' : path.value)?.replace(/^\\/+/, '');\n\n// A Set to track folder names to avoid duplicates\nconst folderSet = new Set();\n\nconst items = outputs.objects?.flatMap(o => {\n  const relativeKey = o.Key.slice(prefix.length);\n\n  if (!o.Key.startsWith(prefix) || relativeKey === '') {\n    return [];\n  }\n\n  const parts = relativeKey.split('/');\n  const isFolder = parts.length > 1;\n  const isSelf = relativeKey === '';\n\n  if (isSelf) return [];\n\n  if (isFolder) {\n    // Implied folder\n    const folderName = parts[0];\n    if (!folderSet.has(folderName)) {\n      folderSet.add(folderName);\n      return [{\n        Key: `${prefix}${folderName}/`,\n        type: \"Folder\",\n        name: folderName\n      }];\n    }\n    return [];\n  } else {\n    // It's a file\n    const type = o.Key.split('.').pop();\n    return [{\n      ...o,\n      type,\n      name: parts[0]\n    }];\n  }\n}) || [];\n\n// Sort folders before files\nconst sortedItems = items.sort((a, b) => {\n  if (a.type === 'Folder' && b.type === 'Folder') {\n    return a.name.localeCompare(b.name);\n  }\n  if (a.type === 'Folder') return -1;\n  if (b.type === 'Folder') return 1;\n  return a.name.localeCompare(b.name);\n}).map(o => ({\n  ...o,\n  type_with_icon: o.type === 'Folder' ? '🗂️ Folder' : `📄 ${o.type}`\n}));\n\nreturn sortedItems;})(self.rawOutputs)}",
          "spec": {
            "connectionId": "2a8a6d56-4c60-4772-9f1e-69bafed9f0ae",
            "fqn": "com.datadoghq.aws.s3.listObjects",
            "inputs": {
              "bucket": "${listBucketsTable.selectedRow?.content?.Name}",
              "region": "us-east-1"
            }
          }
        }
      },
