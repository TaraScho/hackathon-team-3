        "id": "c14ae1a6-abb0-42cf-8783-2c673c9b50d6",
        "name": "GetObject",
        "type": "action",
        "properties": {
          "condition": "${!!listBucketsTable.selectedRow && !!listObjectsTable.selectedRow && listObjectsTable.selectedRow.content.type !== \"Folder\"}",
          "onlyTriggerManually": true,
          "spec": {
            "connectionId": "2a8a6d56-4c60-4772-9f1e-69bafed9f0ae",
