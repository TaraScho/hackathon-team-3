{
    "queries": [
      {
        "id": "56e2b52b-9317-4c55-b1ef-783bbd2c529d",
        "name": "listFunctions",
        "type": "action",
        "properties": {
          "onlyTriggerManually": false,
          "outputs": "${((outputs) => {// Use `outputs` to reference the query's unformatted output.\n\n// TODO: Apply transformations to the raw query output\n\nreturn outputs.functions?.map(f => {\n    return {\n        ...f,\n        MemorySize: f.MemorySize * 1048576 //convert MB to B for proper formatting\n    }\n}).filter(f => {\n    const matchesName = name.value?.length ? f.FunctionName?.toLowerCase().includes(name.value.toLowerCase()) : true;\n    const matchesArchitecture = (architecture.value?.length && architecture.value !== 'Any Architecture') ? f.Architectures.includes(architecture.value) : true;\n\n    return matchesName && matchesArchitecture;\n});})(self.rawOutputs)}",
          "showToastOnError": true,
          "spec": {
            "connectionId": "2a8a6d56-4c60-4772-9f1e-69bafed9f0ae",
            "fqn": "com.datadoghq.aws.lambda.listAWSLambdaFunction",
            "inputs": {
              "limit": 50,
              "region": "us-east-1"
            }
          }
        }
      },
      {
        "id": "d2ec73b3-cad6-43c8-af45-e5aa03108496",
        "name": "describeFunction",
        "type": "action",
        "properties": {
