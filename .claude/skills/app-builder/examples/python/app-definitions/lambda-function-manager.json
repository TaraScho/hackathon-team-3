          "spec": {
            "connectionId": "2a8a6d56-4c60-4772-9f1e-69bafed9f0ae",
            "fqn": "com.datadoghq.aws.lambda.getAWSLambdaFunction",
            "inputs": {
              "region": "us-east-1",
              "resourceId": "${table0.selectedRow?.content?.Arn}"
            }
          }
        },
        "events": [
          {
            "modalName": "modal0",
            "name": "executionFinished",
            "type": "openModal"
          }
        ]
      },
      {
        "id": "23c690a7-831b-4de2-866b-43b843f24c2d",
        "name": "invokeFunction",
        "type": "action",
        "properties": {
          "onlyTriggerManually": true,
          "requiresConfirmation": true,
          "showToastOnError": true,
          "spec": {
            "connectionId": "2a8a6d56-4c60-4772-9f1e-69bafed9f0ae",
            "fqn": "com.datadoghq.aws.lambda.invoke_lambda",
            "inputs": {
              "functionName": "${describeFunction.outputs?.function?.Arn}",
              "inputPayload": "${jsonInput0.value}",
              "invocationType": "Event",
              "region": "us-east-1"
            }
          }
        },
        "events": [
          {
            "modalName": "modal0",
            "name": "executionFinished",
            "type": "closeModal"
          }
        ]
      }
