        "properties": {
          "outputs": "${(() => {let desiredCapacity = describeAutoScalingGroup0?.outputs?.autoScalingGroup?.DesiredCapacity;\n\nif (action.value === 'UP') {\n    desiredCapacity += 1;\n} else if (action.value === 'DOWN') {\n    if (desiredCapacity > 0) {\n        desiredCapacity -= 1;\n    }\n} else if (action.value === 'MAX') {\n    desiredCapacity = describeAutoScalingGroup0?.outputs?.autoScalingGroup?.MaxSize;\n} else if (action.value === 'MIN') {\n    desiredCapacity = describeAutoScalingGroup0?.outputs?.autoScalingGroup?.MinSize;\n}\n\nreturn desiredCapacity;})()}"
        }
