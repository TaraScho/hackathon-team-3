{
  "queries": [
    {
      "id": "2c636319-35aa-4010-941c-59bd82ecc48a",
      "name": "listFunctions",
      "type": "action",
      "properties": {
        "onlyTriggerManually": false,
        "outputs": "${((outputs) => {\nreturn outputs.functions?.map(f => {\n    return {\n        ...f,\n        MemorySize: f.MemorySize * 1048576 //convert MB to B for proper formatting\n    }\n}).filter(f => {\n    const matchesName = name.value?.length ? f.FunctionName?.toLowerCase().includes(name.value.toLowerCase()) : true;\n    const matchesArchitecture = (architecture.value?.length && architecture.value !== 'Any Architecture') ? f.Architectures.includes(architecture.value) : true;\n\n    return matchesName && matchesArchitecture;\n});})(self.rawOutputs)}",
        "showToastOnError": true,
        "spec": {
          "fqn": "com.datadoghq.aws.lambda.listAWSLambdaFunction",
          "inputs": {
            "limit": 50,
            "region": "us-east-1"
          },
          "connectionId": "__CONNECTION_ID__"
        }
      }
    },
    {
      "id": "48586a1e-2ec9-4316-acba-c991efa9659f",
      "name": "describeFunction",
      "type": "action",
      "properties": {
        "onlyTriggerManually": true,
        "spec": {
          "fqn": "com.datadoghq.aws.lambda.getAWSLambdaFunction",
          "inputs": {
            "region": "us-east-1",
            "resourceId": "${table0.selectedRow?.content?.Arn}"
          },
          "connectionId": "__CONNECTION_ID__"
        }
      },
      "events": [
        {
          "modalName": "modal0",
          "name": "executionFinished",
          "type": "openModal"
        }
      ]
    },
    {
      "id": "2b3a0405-95c3-4f40-bd63-de8ceef876b7",
      "name": "invokeFunction",
      "type": "action",
      "properties": {
        "onlyTriggerManually": true,
        "requiresConfirmation": true,
        "showToastOnError": true,
        "spec": {
          "fqn": "com.datadoghq.aws.lambda.invoke_lambda",
          "inputs": {
            "functionName": "${describeFunction.outputs?.function?.Arn}",
            "inputPayload": "${jsonInput0.value}",
            "invocationType": "Event",
            "region": "us-east-1"
          },
          "connectionId": "__CONNECTION_ID__"
        }
      },
      "events": [
        {
          "modalName": "modal0",
          "name": "executionFinished",
          "type": "closeModal"
        }
      ]
    }
  ],
