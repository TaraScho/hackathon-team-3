{
    "queries": [
      {
        "id": "83f26061-219b-4f05-af70-3ae1ce9e253e",
        "name": "sqsList",
        "type": "action",
        "properties": {
          "onlyTriggerManually": false,
          "outputs": "${((outputs) => {const lastUpdated = new Date(Date.now());\nreturn { \n  queues: outputs?.queues?.filter((q) => {\n    const matchesName = name.value?.length ? q.name.toLowerCase().includes(name.value.toLowerCase()) : true;\n\n    return q.attributes.RedrivePolicy && matchesName;\n  }).map((q) => {\n    const arn =\n      JSON.parse(q.attributes.RedrivePolicy).deadLetterTargetArn;\n    const dlq =\n      arn &&\n      self.rawOutputs?.queues?.find((i) => i.attributes.QueueArn === arn);\n    return {\n      name: q.name,\n      length: q.attributes.ApproximateNumberOfMessages > 0 ? q.attributes.ApproximateNumberOfMessages : 'empty',\n      dlq_length: dlq && dlq.attributes.ApproximateNumberOfMessages > 0 ? dlq.attributes.ApproximateNumberOfMessages : 'empty',\n      dlq_name: dlq && dlq.name,\n    };\n  }), \n  lastUpdated: lastUpdated.toLocaleTimeString('en-US')\n};\n})(self.rawOutputs)}",
          "requiresConfirmation": false,
          "showToastOnError": true,
          "spec": {
            "connectionId": "__CONNECTION_ID__",
            "fqn": "com.datadoghq.aws.sqs.list_queues_with_attributes",
            "inputs": {
              "region": "us-east-1"
            }
          }
        }
      },
      {
        "id": "e0316b02-992c-4152-9f43-f794d41a3b2f",
        "name": "dlqPeek",
        "type": "action",
        "properties": {
          "onlyTriggerManually": true,
          "outputs": "${((outputs) => {return outputs?.messages ?? []})(self.rawOutputs)}",
          "requiresConfirmation": false,
          "spec": {
            "connectionId": "__CONNECTION_ID__",
            "fqn": "com.datadoghq.aws.sqs.receive_messages",
            "inputs": {
              "deleteMessages": false,
              "maxNumberOfMessages": 5,
              "queueName": "${table0.selectedRow?.content?.dlq_name}",
              "region": "us-east-1"
            }
          }
        }
      },
      {
        "id": "e043bd7c-1b57-44c4-b3f1-6eb0434cdc30",
        "name": "sqsPurge",
        "type": "action",
        "properties": {
          "onlyTriggerManually": true,
          "requiresConfirmation": true,
          "showToastOnError": true,
          "spec": {
            "connectionId": "__CONNECTION_ID__",
            "fqn": "com.datadoghq.aws.sqs.purge_queue",
            "inputs": {
              "queueName": "${table0.selectedRow?.content?.dlq_name}",
              "region": "us-east-1"
            }
          }
        },
        "events": [
          {
            "name": "executionFinished",
            "queryName": "sqsList",
            "type": "triggerQuery"
          }
        ]
      },
      {
        "id": "e6c8c1fb-e109-488f-a515-1c79f1c60837",
        "name": "sqsRedrive",
        "type": "action",
        "properties": {
          "onlyTriggerManually": true,
          "requiresConfirmation": true,
          "showToastOnError": true,
          "spec": {
            "connectionId": "__CONNECTION_ID__",
            "fqn": "com.datadoghq.aws.sqs.move_messages",
            "inputs": {
              "fromQueueName": "${table0.selectedRow?.content?.dlq_name}",
              "region": "us-east-1",
              "toQueueName": "${table0.selectedRow?.content?.name}"
            }
          }
        },
        "events": [
          {
            "callback": "${() => { setTimeout(() => sqsList.fetch(), 2000) }}",
            "name": "executionFinished",
            "type": "custom"
          }
        ]
      },
      {
        "id": "f86879dc-b4e5-4733-89a2-a6dbdc8e0f32",
        "name": "sourcePeek",
        "type": "action",
        "properties": {
          "onlyTriggerManually": true,
          "outputs": "${((outputs) => {// Use `outputs` to reference the query's unformatted output.\n\n// TODO: Apply transformations to the raw query output\n\nreturn outputs?.messages ?? []})(self.rawOutputs)}",
          "spec": {
            "connectionId": "__CONNECTION_ID__",
            "fqn": "com.datadoghq.aws.sqs.receive_messages",
            "inputs": {
              "deleteMessages": false,
              "maxNumberOfMessages": 5,
              "queueName": "${table0.selectedRow?.content?.name}",
              "region": "us-east-1"
            }
          }
        }
      }
