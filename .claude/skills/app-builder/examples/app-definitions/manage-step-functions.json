        "id": "02af3ab2-7b47-4f10-8267-72d671290166",
        "name": "listStateMachines",
        "type": "action",
        "properties": {
          "onlyTriggerManually": false,
          "outputs": "${((outputs) => {// Use `outputs` to reference the query's unformatted output.\n\n// TODO: Apply transformations to the raw query output\n\nreturn outputs.stateMachines.filter(s => {\n    const matchesName = search.value?.length ? s.name.toLowerCase().includes(search.value.toLowerCase()) : true;\n    const matchesType = (type.value && type.value !== 'Any Type') ? s.type ===  type.value : true;\n\n    return matchesName && matchesType;\n}).map( s => {\n\n    return {\n        ...s,\n        name: {\n            label: s.name\n        }\n    }\n});})(self.rawOutputs)}",
          "spec": {
            "connectionId": "__CONNECTION_ID__",
            "fqn": "com.datadoghq.aws.stepfunctions.listStateMachines",
            "inputs": {
              "region": "us-east-1"
            }
          }
        }
      },
