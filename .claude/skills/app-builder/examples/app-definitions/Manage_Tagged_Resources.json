      "name": "getResourcesByTags0",
      "type": "action",
      "properties": {
        "onlyTriggerManually": false,
        "showToastOnError": true,
        "spec": {
          "fqn": "com.datadoghq.aws.resourcetagging.getResourcesByTags",
          "inputs": {
            "filters": "${[{key: 'service', values: [tagValueInput.value || '__SERVICE_TAG_VALUE__']}]}",
            "region": "${regionSelector.value || 'us-east-1'}",
            "resourceTypes": ["__RESOURCE_TYPES__"]
          },
          "connectionId": "__CONNECTION_ID__"
        }
      }
    },
    {
      "id": "6b61918f-73e9-445f-bdfd-2bab23965a80",
