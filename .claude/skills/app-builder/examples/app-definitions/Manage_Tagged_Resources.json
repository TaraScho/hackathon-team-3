        "showToastOnError": true,
        "spec": {
          "fqn": "com.datadoghq.aws.resourcetagging.untagResources",
          "inputs": {
            "region": "${regionSelector.value || 'us-east-1'}",
            "resourceArns": [
              "${taggedResourcesTable.selectedRowData.resourceArn}"
            ],
            "tagKeys": [
              "service"
            ]
          },
          "connectionId": "__CONNECTION_ID__"
        }
      }
    }
