{
    "queries": [
      {
        "id": "e8b2f370-4ae5-4ea5-807a-1c8936aad2c6",
        "name": "listInstances",
        "type": "action",
        "properties": {
          "outputs": "${((outputs) => {// Use `outputs` to reference the query's unformatted output.\n\n// TODO: Apply transformations to the raw query output\n\nreturn {\n    instances: outputs.instances.map(i => {\n        const name = i.Tags.find(tag => tag.Key === 'Name')?.Value\n        return {\n            ...i,\n            Name: name,\n            State: i.State.Name\n        }\n    }).filter(i => {\n\n        const matchesName = name.value?.length ? i.Name?.toLowerCase().includes(name.value) : true;\n        const matchesInstanceType = instanceType.value !== 'All Instance Types' ? i.InstanceType === instanceType.value : true;\n        const matchesState = state.value !== 'All States' ? i.State === state.value : true;\n\n        return matchesName && matchesInstanceType && matchesState;\n    })\n}})(self.rawOutputs)}",
          "spec": {
            "connectionId": "__CONNECTION_ID__",
            "fqn": "com.datadoghq.aws.ec2.describe_ec2_instances",
            "inputs": {
              "maxResults": 500,
              "region": "us-east-1"
            }
          }
        }
      },
      {
        "id": "6b497c50-b989-44c9-9b30-f16a3d5945ac",
        "name": "startInstance",
        "type": "action",
        "properties": {
          "onlyTriggerManually": true,
          "requiresConfirmation": true,
          "showToastOnError": true,
          "spec": {
            "connectionId": "__CONNECTION_ID__",
            "fqn": "com.datadoghq.aws.ec2.start_ec2_instance",
            "inputs": {
              "instanceId": "${table0.selectedRow?.content.InstanceId}",
              "region": "us-east-1"
            }
          }
        },
        "events": [
          {
            "name": "executionFinished",
            "queryName": "listInstances",
            "type": "triggerQuery"
          }
        ]
      },
